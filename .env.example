# Copy this file to .env and fill values locally.
# Never commit real API keys, tokens, or organization-specific service addresses.

# MinerU cloud API
MINERU_API_TOKEN=
MINERU_API_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=
MINERU_IS_OCR=
MINERU_ENABLE_FORMULA=
MINERU_ENABLE_TABLE=
MINERU_LANGUAGE=
MINERU_EXTRA_FORMATS=
MINERU_NO_CACHE=
MINERU_PAGE_RANGES=

# Qiniu Kodo upload settings used by the MinerU fallback flow
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_UPLOAD_HOST=
QINIU_PUBLIC_BASE_URL=
QINIU_KEY_PREFIX=
QINIU_UPLOAD_TOKEN_TTL_SECONDS=

# Frontend service endpoints
# Comma-separated legacy MinerU addresses. Keep blank for public/default builds.
VITE_LEGACY_MINERU_ENDPOINTS=
# Optional Popo enhancement service. Keep blank unless a private deployment provides it.
VITE_POPO_ENHANCEMENT_ENDPOINT=
